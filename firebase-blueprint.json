{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["client", "admin"] },
        "phone": { "type": "string" },
        "location": { "type": "string" },
        "cedula": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Product": {
      "title": "Product",
      "description": "Base product available for customization",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "basePrice": { "type": "number" },
        "wholesalePrice": { "type": "number" },
        "wholesaleThreshold": { "type": "integer" },
        "imageUrl": { "type": "string" },
        "category": { "type": "string" },
        "colors": { "type": "array", "items": { "type": "string" } },
        "sizes": { "type": "array", "items": { "type": "string" } },
        "techniques": { "type": "array", "items": { "type": "string" } }
      }
    },
    "Order": {
      "title": "Order",
      "description": "Customer order details and status",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "items": { "type": "array" },
        "totalAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["recibido", "validando", "produccion", "listo", "entregado"] },
        "securityCode": { "type": "string" },
        "paymentReference": { "type": "string" },
        "depositPaid": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Category": {
      "title": "Category",
      "description": "Product collection for home page",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "order": { "type": "integer" }
      },
      "required": ["name", "order"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Store user profiles"
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Catalog of base products"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Customer orders"
    },
    "/categories/{categoryId}": {
      "schema": "Category",
      "description": "Product categories"
    }
  }
}
